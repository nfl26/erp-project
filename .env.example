# ============================================================
# ERP Local — Variables de entorno
# Copie este archivo a .env y ajuste los valores:
#   cp .env.example .env
# NUNCA commitee el archivo .env real.
# ============================================================

# ── PostgreSQL ───────────────────────────────────────────────
# Usuario administrador de la base de datos
POSTGRES_USER=erp_admin

# Password del usuario administrador (cámbielo en staging/producción)
POSTGRES_PASSWORD=changeme123

# Nombre de la base de datos principal
POSTGRES_DB=erp_db

# Puerto en el host para acceder a PostgreSQL desde el IDE / psql
POSTGRES_PORT=5432

# ── Redis ────────────────────────────────────────────────────
# Puerto en el host para acceder a Redis
REDIS_PORT=6379

# ── pgAdmin 4 ────────────────────────────────────────────────
# Email de login en la UI de pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@erp.local

# Password de login en la UI de pgAdmin
PGADMIN_DEFAULT_PASSWORD=changeme123

# Puerto en el host para acceder a pgAdmin
PGADMIN_PORT=5050

# ── RabbitMQ — usuario administrador ─────────────────────────
# Usuario admin del broker (accede a Management UI y todos los vhosts)
RABBITMQ_DEFAULT_USER=erp_admin

# Password del usuario admin
RABBITMQ_DEFAULT_PASS=changeme123

# Puerto AMQP (conexiones de la aplicación)
RABBITMQ_AMQP_PORT=5672

# Puerto de la Management UI
RABBITMQ_MGMT_PORT=15672

# ── RabbitMQ — usuario publicador ────────────────────────────
# Usuario con permisos de escritura en /erp (para servicios que publican eventos)
RABBITMQ_PUBLISHER_USER=dev-publisher

# Password del publicador — cambiar en staging
RABBITMQ_PUBLISHER_PASSWORD=publisher123

# ── RabbitMQ — usuario consumidor ────────────────────────────
# Usuario con permisos de lectura en /erp (para servicios que consumen eventos)
RABBITMQ_CONSUMER_USER=dev-consumer

# Password del consumidor — cambiar en staging
RABBITMQ_CONSUMER_PASSWORD=consumer123
