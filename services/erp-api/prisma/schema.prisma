// Generado manualmente desde information_schema de PostgreSQL — Commit B (T-004)
// URL de conexión: prisma.config.ts (CLI) y PrismaService adapter (runtime)
// Schema de BD: schema.prisma es la fuente de verdad. Ver docs/prisma-workflow.md

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["views"]
}

datasource db {
  provider = "postgresql"
  schemas  = ["public", "tenant_erp"]
}

// ─── Enums (tenant_erp) ─────────────────────────────────────────────────────

enum RolUsuario {
  admin
  vendedor
  operario
  comprador

  @@schema("tenant_erp")
  @@map("rol_usuario")
}

enum EstadoPedido {
  borrador
  confirmado
  en_produccion
  listo
  entregado
  cancelado

  @@schema("tenant_erp")
  @@map("estado_pedido")
}

enum CanalVenta {
  instagram
  whatsapp
  presencial
  mercadolibre
  web

  @@schema("tenant_erp")
  @@map("canal_venta")
}

enum EstadoOrden {
  pendiente
  en_proceso
  finalizado

  @@schema("tenant_erp")
  @@map("estado_orden")
}

enum EstadoVenta {
  pendiente
  parcial
  pagado

  @@schema("tenant_erp")
  @@map("estado_venta")
}

enum MedioPago {
  efectivo
  transferencia
  mercadopago
  debito
  credito

  @@schema("tenant_erp")
  @@map("medio_pago")
}

enum EstadoProducto {
  activo
  por_cortar
  cortado
  pendiente
  no_cortado
  sin_diseno

  @@schema("tenant_erp")
  @@map("estado_producto")
}

// ─── Model: Tenant (schema public) ───────────────────────────────────────────

model Tenant {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug       String    @unique @db.VarChar
  nombre     String    @db.VarChar
  activo     Boolean?  @default(true)
  config     Json?
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  updated_at DateTime? @db.Timestamptz(6)

  @@map("tenants")
  @@schema("public")
}

// ─── Models: schema tenant_erp ──────────────────────────────────────────────

model Categoria {
  id_categoria Int     @id @default(autoincrement())
  nombre       String  @db.VarChar(100)
  descripcion  String?

  productos Producto[]

  @@map("categorias")
  @@schema("tenant_erp")
}

model Comprador {
  id_comprador Int      @id @default(autoincrement())
  nombre       String   @db.VarChar(100)
  apellido     String?  @db.VarChar(100)
  email        String?  @db.VarChar(200)
  telefono     String?  @db.VarChar(30)
  instagram    String?  @db.VarChar(100)
  direccion    String?
  created_at   DateTime @default(now()) @db.Timestamptz(6)

  pedidos Pedido[]

  @@map("compradores")
  @@schema("tenant_erp")
}

model Proveedor {
  id_proveedor Int     @id @default(autoincrement())
  nombre       String  @db.VarChar(200)
  contacto     String? @db.VarChar(200)
  telefono     String? @db.VarChar(30)
  email        String? @db.VarChar(200)
  direccion    String?
  url_catalogo String?
  activo       Boolean @default(true)

  compras Compra[]

  @@map("proveedores")
  @@schema("tenant_erp")
}

model Usuario {
  id_usuario    Int        @id @default(autoincrement())
  nombre        String     @db.VarChar(100)
  apellido      String     @db.VarChar(100)
  email         String     @unique @db.VarChar(200)
  password_hash String
  rol           RolUsuario @default(operario)
  activo        Boolean    @default(true)
  created_at    DateTime   @default(now()) @db.Timestamptz(6)

  compras      Compra[]
  mano_de_obra ManoDeObra[]
  vendedores   Vendedor[]

  @@map("usuarios")
  @@schema("tenant_erp")
}

model Vendedor {
  id_vendedor  Int     @id @default(autoincrement())
  id_usuario   Int
  comision_pct Decimal @default(0.00) @db.Decimal(5, 2)
  zona         String? @db.VarChar(100)

  usuario Usuario  @relation(fields: [id_usuario], references: [id_usuario])
  pedidos Pedido[]
  ventas  Venta[]

  @@map("vendedores")
  @@schema("tenant_erp")
}

model ManoDeObra {
  id_operario  Int     @id @default(autoincrement())
  id_usuario   Int
  especialidad String  @db.VarChar(100)
  valor_hora   Decimal @default(0.00) @db.Decimal(10, 2)
  activo       Boolean @default(true)

  usuario            Usuario           @relation(fields: [id_usuario], references: [id_usuario])
  ordenes_produccion OrdenProduccion[]

  @@map("mano_de_obra")
  @@schema("tenant_erp")
}

model Material {
  id_material      Int      @id @default(autoincrement())
  cod_interno      String?  @db.VarChar(20)
  tipo             String   @db.VarChar(100)
  marca            String?  @db.VarChar(100)
  descripcion      String?  @db.VarChar(200)
  grosor_mm        Decimal? @db.Decimal(5, 2)
  valor_plancha    Decimal  @default(0.00) @db.Decimal(10, 2)
  ancho_cm         Decimal? @db.Decimal(10, 2)
  alto_cm          Decimal? @db.Decimal(10, 2)
  cm2_por_plancha  Decimal? @db.Decimal(12, 2)
  tipo_medida      String?  @db.VarChar(20)
  proveedor        String?  @db.VarChar(200)
  codigo_proveedor String?  @db.VarChar(100)
  url_referencia   String?
  activo           Boolean  @default(true)

  detalle_compras DetalleCompra[]
  recetas         Receta[]

  @@map("materiales")
  @@schema("tenant_erp")
}

model Compra {
  id_compra     Int      @id @default(autoincrement())
  id_proveedor  Int
  id_usuario    Int
  fecha_compra  DateTime @db.Date
  total         Decimal? @db.Decimal(12, 2)
  factura_nro   String?  @db.VarChar(100)
  observaciones String?
  created_at    DateTime @default(now()) @db.Timestamptz(6)

  proveedor Proveedor     @relation(fields: [id_proveedor], references: [id_proveedor])
  usuario   Usuario       @relation(fields: [id_usuario], references: [id_usuario])
  detalles  DetalleCompra[]

  @@map("compras")
  @@schema("tenant_erp")
}

model DetalleCompra {
  id_detalle_compra Int      @id @default(autoincrement())
  id_compra         Int
  id_material       Int
  cantidad          Decimal  @db.Decimal(10, 2)
  unidad            String   @default("plancha") @db.VarChar(50)
  precio_unitario   Decimal  @db.Decimal(10, 2)
  subtotal          Decimal? @db.Decimal(10, 2)

  compra   Compra   @relation(fields: [id_compra], references: [id_compra])
  material Material @relation(fields: [id_material], references: [id_material])

  @@map("detalle_compra")
  @@schema("tenant_erp")
}

model Producto {
  id_producto  Int            @id @default(autoincrement())
  id_categoria Int?
  codigo       String?        @unique @db.VarChar(50)
  nombre       String         @db.VarChar(200)
  descripcion  String?
  estado       EstadoProducto @default(activo)
  activo       Boolean        @default(true)

  categoria      Categoria?      @relation(fields: [id_categoria], references: [id_categoria])
  grabados       Grabado[]
  precios_venta  PrecioVenta[]
  recetas        Receta[]
  detalle_pedido DetallePedido[]

  @@map("productos")
  @@schema("tenant_erp")
}

model NivelPrecioCorte {
  id_nivel          Int     @id @default(autoincrement())
  nivel             Int     @unique
  precio_por_minuto Decimal @db.Decimal(10, 2)
  descripcion       String? @db.VarChar(200)

  ordenes_produccion OrdenProduccion[]

  @@map("niveles_precio_corte")
  @@schema("tenant_erp")
}

model Receta {
  id_receta                Int      @id @default(autoincrement())
  id_producto              Int
  id_material              Int
  parte                    String?  @db.VarChar(100)
  tamano_ancho_mm          Decimal? @db.Decimal(8, 2)
  tamano_alto_mm           Decimal? @db.Decimal(8, 2)
  tiempo_seg               Decimal? @db.Decimal(12, 6)
  requiere_sublimacion     Boolean  @default(false)
  costo_sublimacion_unidad Decimal? @db.Decimal(10, 2)
  requiere_barniz          Boolean  @default(false)
  requiere_corcho          Boolean  @default(false)
  costo_material_calculado Decimal? @db.Decimal(10, 2)
  costo_tiempo_base        Decimal? @db.Decimal(10, 2)
  costo_embalaje           Decimal? @default(0) @db.Decimal(10, 2)
  valor_neto               Decimal? @db.Decimal(10, 2)
  version                  Int      @default(1)
  activa                   Boolean  @default(true)
  notas                    String?

  producto           Producto          @relation(fields: [id_producto], references: [id_producto])
  material           Material          @relation(fields: [id_material], references: [id_material])
  parametros_corte   ParametroCorte[]
  ordenes_produccion OrdenProduccion[]
  detalle_pedido     DetallePedido[]

  @@map("recetas")
  @@schema("tenant_erp")
}

model ParametroCorte {
  id_parametro        Int      @id @default(autoincrement())
  id_receta           Int
  tecnica             String?  @db.VarChar(50)
  velocidad           Decimal? @db.Decimal(8, 2)
  potencia_pct        Decimal? @db.Decimal(5, 2)
  interlineado        Decimal? @db.Decimal(5, 2)
  pasadas             Int?     @default(1)
  tiempo_por_lote_seg Decimal? @db.Decimal(12, 6)
  notas               String?

  receta Receta @relation(fields: [id_receta], references: [id_receta])

  @@map("parametros_corte")
  @@schema("tenant_erp")
}

model Grabado {
  id_grabado    Int      @id @default(autoincrement())
  id_producto   Int?
  nombre_diseno String?  @db.VarChar(200)
  ancho_mm      Decimal? @db.Decimal(8, 2)
  alto_mm       Decimal? @db.Decimal(8, 2)
  tecnica       String?  @db.VarChar(50)
  velocidad     Decimal? @db.Decimal(8, 2)
  potencia_pct  Decimal? @db.Decimal(5, 2)
  interlineado  Decimal? @db.Decimal(5, 2)
  minutos       Decimal? @db.Decimal(10, 6)
  vel_marcado   Decimal? @db.Decimal(8, 2)
  pot_marcado   Decimal? @db.Decimal(5, 2)

  producto Producto? @relation(fields: [id_producto], references: [id_producto])

  @@map("grabados")
  @@schema("tenant_erp")
}

model PrecioVenta {
  id_precio          Int      @id @default(autoincrement())
  id_producto        Int
  cantidad_desde     Int      @default(1)
  precio_unitario    Decimal  @db.Decimal(10, 2)
  precio_con_argolla Decimal? @db.Decimal(10, 2)
  observacion        String?  @db.VarChar(200)

  producto Producto @relation(fields: [id_producto], references: [id_producto])

  @@map("precios_venta")
  @@schema("tenant_erp")
}

model Pedido {
  id_pedido               Int          @id @default(autoincrement())
  id_comprador            Int
  id_vendedor             Int?
  fecha_pedido            DateTime     @default(now()) @db.Timestamptz(6)
  fecha_entrega_prometida DateTime?    @db.Date
  estado                  EstadoPedido @default(borrador)
  canal_venta             CanalVenta?
  observaciones           String?
  created_at              DateTime     @default(now()) @db.Timestamptz(6)

  comprador          Comprador         @relation(fields: [id_comprador], references: [id_comprador])
  vendedor           Vendedor?         @relation(fields: [id_vendedor], references: [id_vendedor])
  detalles           DetallePedido[]
  ordenes_produccion OrdenProduccion[]
  ventas             Venta[]

  @@map("pedidos")
  @@schema("tenant_erp")
}

model DetallePedido {
  id_detalle               Int      @id @default(autoincrement())
  id_pedido                Int
  id_producto              Int
  id_receta                Int?
  cantidad                 Int      @default(1)
  precio_unitario_acordado Decimal  @db.Decimal(10, 2)
  personalizacion          String?
  subtotal                 Decimal? @db.Decimal(10, 2)

  pedido   Pedido   @relation(fields: [id_pedido], references: [id_pedido])
  producto Producto @relation(fields: [id_producto], references: [id_producto])
  receta   Receta?  @relation(fields: [id_receta], references: [id_receta])

  @@map("detalle_pedido")
  @@schema("tenant_erp")
}

model OrdenProduccion {
  id_orden                Int         @id @default(autoincrement())
  id_pedido               Int
  id_receta               Int
  id_nivel                Int
  id_operario             Int?
  cantidad_a_producir     Int         @default(1)
  fecha_inicio            DateTime?   @db.Timestamptz(6)
  fecha_fin               DateTime?   @db.Timestamptz(6)
  estado                  EstadoOrden @default(pendiente)
  costo_material_total    Decimal?    @db.Decimal(10, 2)
  costo_corte_total       Decimal?    @db.Decimal(10, 2)
  costo_sublimacion_total Decimal?    @db.Decimal(10, 2)
  costo_mano_obra_total   Decimal?    @db.Decimal(10, 2)
  costo_total             Decimal?    @db.Decimal(10, 2)

  pedido   Pedido           @relation(fields: [id_pedido], references: [id_pedido])
  receta   Receta           @relation(fields: [id_receta], references: [id_receta])
  nivel    NivelPrecioCorte @relation(fields: [id_nivel], references: [id_nivel])
  operario ManoDeObra?      @relation(fields: [id_operario], references: [id_operario])

  @@map("ordenes_produccion")
  @@schema("tenant_erp")
}

model Venta {
  id_venta    Int         @id @default(autoincrement())
  id_pedido   Int
  id_vendedor Int?
  fecha_venta DateTime    @default(now()) @db.Timestamptz(6)
  total_bruto Decimal     @db.Decimal(12, 2)
  descuento   Decimal     @default(0.00) @db.Decimal(10, 2)
  total_final Decimal?    @db.Decimal(12, 2)
  estado      EstadoVenta @default(pendiente)

  pedido   Pedido    @relation(fields: [id_pedido], references: [id_pedido])
  vendedor Vendedor? @relation(fields: [id_vendedor], references: [id_vendedor])
  pagos    Pago[]

  @@map("ventas")
  @@schema("tenant_erp")
}

model Pago {
  id_pago     Int       @id @default(autoincrement())
  id_venta    Int
  fecha_pago  DateTime  @db.Timestamptz(6)
  monto       Decimal   @db.Decimal(12, 2)
  medio_pago  MedioPago
  referencia  String?   @db.VarChar(200)
  observacion String?   @db.VarChar(300)

  venta Venta @relation(fields: [id_venta], references: [id_venta])

  @@map("pagos")
  @@schema("tenant_erp")
}

// ─── Views (tenant_erp) ─────────────────────────────────────────────────────
// Columnas inferidas desde la tabla subyacente. Verificar con:
//   SELECT column_name, data_type FROM information_schema.columns
