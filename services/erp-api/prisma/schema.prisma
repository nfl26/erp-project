view VMaterialesActivos {
  id_material      Int      @unique
  cod_interno      String?  @db.VarChar(20)
  tipo             String   @db.VarChar(100)
  marca            String?  @db.VarChar(100)
  descripcion      String?  @db.VarChar(200)
  grosor_mm        Decimal? @db.Decimal(5, 2)
  valor_plancha    Decimal  @db.Decimal(10, 2)
  ancho_cm         Decimal? @db.Decimal(10, 2)
  alto_cm          Decimal? @db.Decimal(10, 2)
  cm2_por_plancha  Decimal? @db.Decimal(12, 2)
  tipo_medida      String?  @db.VarChar(20)
  proveedor        String?  @db.VarChar(200)
  codigo_proveedor String?  @db.VarChar(100)
  url_referencia   String?
  activo           Boolean

  @@map("v_materiales_activos")
  @@schema("tenant_erp")
}

