{
  "name": "erp-api",
  "version": "0.1.0",
  "description": "ERP API — NestJS 10 + Fastify + Prisma (monolito modular)",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start:dev":        "nest start --watch",
    "build":            "nest build",
    "lint":             "eslint \"{src,test}/**/*.ts\" --fix",
    "typecheck":        "tsc --noEmit",
    "test":             "jest",
    "test:integration": "jest --testPathPattern=\\.integration\\.spec\\.ts$ --runInBand --passWithNoTests",
    "test:e2e":         "jest --config test/jest-e2e.config.ts --runInBand"
  },
  "dependencies": {
    "@fastify/static":          "^6.12.0",
    "@nestjs/common":           "^10.3.0",
    "@nestjs/config":           "^3.2.0",
    "@nestjs/core":             "^10.3.0",
    "@nestjs/event-emitter":    "^2.0.4",
    "@nestjs/platform-fastify": "^10.3.0",
    "@nestjs/swagger":          "^7.3.0",
    "@prisma/client":           "^5.12.0",
    "class-transformer":        "^0.5.1",
    "class-validator":          "^0.14.1",
    "decimal.js":               "^10.4.3",
    "eventemitter2":            "^6.4.9",
    "fastify":                  "^4.26.0",
    "ioredis":                  "^5.3.2",
    "pino":                     "^9.0.0",
    "pino-pretty":              "^11.0.0",
    "reflect-metadata":         "^0.2.0",
    "rxjs":                     "^7.8.1",
    "zod":                      "^3.22.4"
  },
  "devDependencies": {
    "@nestjs/cli":                       "^10.3.0",
    "@nestjs/schematics":                "^10.1.0",
    "@nestjs/testing":                   "^10.3.0",
    "@types/jest":                       "^29.5.12",
    "@types/node":                       "^20.12.0",
    "@types/supertest":                  "^6.0.2",
    "@typescript-eslint/eslint-plugin":  "^7.7.0",
    "@typescript-eslint/parser":         "^7.7.0",
    "eslint":                            "^8.57.0",
    "eslint-config-prettier":            "^9.1.0",
    "eslint-plugin-prettier":            "^5.1.3",
    "jest":                              "^29.7.0",
    "prettier":                          "^3.2.5",
    "prisma":                            "^5.12.0",
    "supertest":                         "^7.0.0",
    "ts-jest":                           "^29.1.2",
    "ts-node":                           "^10.9.2",
    "typescript":                        "^5.4.0"
  }
}
