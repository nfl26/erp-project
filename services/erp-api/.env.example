# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:4200,http://localhost:3001

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://erp_admin:changeme123@localhost:5432/erp_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── RabbitMQ (pendiente extracción microservicios — hoy se usa EventEmitter2) ──
# RABBITMQ_URL=amqp://dev-publisher:publisher123@localhost:5672/erp

# ── Auth — JWT (temporal hasta T-010) ─────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_EXPIRATION=15m

# ── Auth — Keycloak (pendiente T-010) ─────────────────────────────────────────
# KEYCLOAK_ISSUER=http://localhost:8080/realms/erp
# KEYCLOAK_CLIENT_ID=erp-api
# KEYCLOAK_CLIENT_SECRET=change-me

# ── Multi-tenancy ─────────────────────────────────────────────────────────────
DEFAULT_TENANT=demo
